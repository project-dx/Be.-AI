# ============================================================
# Be.カラフル Well-being個別支援AI 環境変数テンプレート
# バックエンドをローカル起動する場合は backend/.env へコピーしてください
#   PowerShell: Copy-Item .env.example backend\.env
#   docker compose の場合はこのファイルを .env にコピーして使用します
# ============================================================

# 実行環境: development / production
# production では --force なしのデモデータ投入が無効になります
ENVIRONMENT=development
DEBUG=true

# データベース接続
# 開発（SQLite）:
DATABASE_URL=sqlite:///./becolorful.db
# 本番（PostgreSQL）の例:
# DATABASE_URL=postgresql+psycopg://user:password@db:5432/becolorful

# JWT署名鍵（本番では必ず32文字以上のランダム文字列へ変更してください）
SECRET_KEY=dev-only-secret-key-change-me-in-production-0000
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AIプロバイダ: mock / gemini
# gemini を使う場合は GEMINI_API_KEY を設定してください（キーが無い場合は自動でmock動作）
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# CORS許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 初期管理者（本番デプロイ用。DBにユーザーが1人もいない場合のみ起動時に作成される）
ADMIN_EMAIL=
ADMIN_PASSWORD=
